---
import { Icon as AstroIcon } from "astro-icon/components";

export interface Props {
  name: "play" | "pause" | "replay";
}

const { name = "pause" } = Astro.props;

const iconName = {
  play: "fluent:play-20-filled",
  pause: "fluent:pause-20-filled",
  replay: "fluent:arrow-counterclockwise-20-filled",
}[name];
---

<style lang="scss">
  :global([data-icon]) {
    width: 24px;
    height: 24px;
    color: currentColor;
  }
</style>

<AstroIcon class={`icon ${name}`} name={iconName} />
