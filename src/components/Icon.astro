---
import { Icon as AstroIcon } from "astro-icon/components";
import { playbackIcons, type PlaybackIconName } from "../lib/icons";

export interface Props {
  name: PlaybackIconName;
}

const { name = "pause" } = Astro.props;
const iconName = playbackIcons[name];
---

<style>
  :global([data-icon]) {
    width: 24px;
    height: 24px;
    color: currentColor;
  }
</style>

<AstroIcon class={`icon ${name}`} name={iconName} />
