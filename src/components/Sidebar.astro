---
import { Icon as AstroIcon } from "astro-icon/components";
import Logo from "./Logo.astro";
import SidebarSection from "./SidebarSection.astro";
import { getDocTree } from "../lib/docs";

const tree = await getDocTree();
---

<style>
  /* Tailwind v4 component-style reference */
  @reference "../style/tailwind-reference.css";

  .sidebar-backdrop,
  .mobile-menu-button {
    @apply sm:hidden;
  }

  .sidebar-backdrop {
    @apply fixed inset-0 z-30 bg-slate-950/50 opacity-0 pointer-events-none transition-opacity duration-200;
  }

  .sidebar-backdrop[data-open="true"] {
    @apply opacity-100 pointer-events-auto;
  }

  aside {
    font-size: 0.9em;
    min-width: 300px;
    @apply py-2 min-w-[250px] lg:min-w-[300px];
    @apply fixed left-0 top-0 z-40 h-full bg-white dark:bg-slate-950 sm:relative sm:z-auto sm:h-auto sm:w-auto sm:bg-transparent;
    width: min(21rem, calc(100vw - 4.5rem));
    max-width: calc(100vw - 1rem);
    border-inline-end: 1px solid rgb(148 163 184 / 0.22);
    border-radius: 0 1.75rem 1.75rem 0;
    box-shadow: 0 18px 48px rgb(15 23 42 / 0.18);
    transform: translateX(calc(-100% + 1.25rem));
    transition: transform 0.24s ease-in-out, box-shadow 0.24s ease-in-out;
  }

  aside[data-open="true"] {
    transform: translateX(0);
    box-shadow: 0 24px 64px rgb(15 23 42 / 0.28);
  }

  @media (min-width: 40rem) {
    aside {
      width: auto;
      max-width: none;
      border-inline-end: 0;
      border-radius: 0;
      box-shadow: none;
      transform: translateX(0);
    }
  }

  aside::after {
    content: "";
    @apply absolute right-2 top-1/2 h-16 w-1 rounded-full bg-blue-500/45 sm:hidden;
    transform: translateY(-50%);
  }

  aside[data-open="true"]::after {
    @apply opacity-0;
  }

  .sticky {
    @apply sm:sticky h-full max-h-screen top-0 w-full flex flex-col;
  }

  .scroll-shadow-top,
  .scroll-shadow-bottom {
    @apply from-white dark:from-black to-transparent z-10 flex-shrink-0;
    @apply w-full h-16 pointer-events-none;
  }

  .scroll-shadow-top {
    @apply bg-gradient-to-b translate-y-full;
    transform: translateY(99%);
  }
  
  .scroll-shadow-bottom {
    @apply bg-gradient-to-t -translate-y-full;
    transform: translateY(-99%);
  }

  .scroll {
    @apply relative w-full overflow-auto px-5 py-10;
    padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 6rem);
  }

  details .content {
    padding-left: 2ch;
    @apply py-2;
  }

  details summary::marker {
    content: "";
  }

  details summary,
  details a {
    @apply relative cursor-pointer py-2;
    padding-left: 2ch;
  }

  details summary {
    @apply flex items-center gap-2;
  }

  details .summary-icon {
    @apply absolute left-0 top-1/2 text-blue-600 dark:text-gray-400/60;
    transition: transform 0.2s ease-in-out;
    transform: translateY(-50%);
  }

  details[open] > summary {
    @apply text-blue-500;
  }

  details[open] > summary .summary-icon {
    transform: translateY(-50%) rotate(90deg);
  }

  details a {
    @apply border-none block font-light;
    @apply no-underline py-3 text-black/75 dark:text-blue-300/80;
    word-break: break-word;
    padding-left: 3ch;
    font-size: 0.9em;
  }

  details a::before {
    transform: translate(calc((1em - 2px) / 2), -50%);
    @apply w-px h-full border-l-[1px] border-dashed border-gray-500/60;
    content: "";
  }

  details a + details {
    @apply pt-6;
  }

  details a.active {
    @apply text-blue-500;
  }

  details a.active::before {
    @apply border-solid border-blue-500/80;
  }

  .mobile-menu-button {
    @apply fixed bottom-4 right-4 z-50 inline-flex items-center gap-2 rounded-full px-4 py-3 text-sm font-semibold text-white shadow-lg;
    @apply bg-slate-950/90 ring-1 ring-white/10 backdrop-blur-md transition-all duration-200;
    @apply dark:bg-blue-500 dark:text-slate-950 dark:ring-blue-300/40;
    bottom: calc(env(safe-area-inset-bottom, 0px) + 1rem);
    right: calc(env(safe-area-inset-right, 0px) + 1rem);
  }

  .mobile-menu-button:hover {
    @apply bg-slate-900 dark:bg-blue-400;
  }

  .mobile-menu-button[aria-expanded="true"] {
    @apply bg-blue-600 text-white ring-blue-300/50 dark:bg-blue-500 dark:text-slate-950;
  }

  .mobile-menu-button :global([data-icon]) {
    @apply h-5 w-5;
  }

  .mobile-menu-label {
    @apply tracking-[0.14em] uppercase;
  }
</style>

<button
  class="sidebar-backdrop"
  type="button"
  data-sidebar-overlay
  data-open="false"
  aria-label="Close documentation navigation"
></button>

<aside id="docs-sidebar" data-sidebar data-open="false">
  <Logo />
  <div class="sticky">
    <div class="scroll-shadow-top"></div>
    <div class="scroll">
      {tree.map((node) => <SidebarSection node={node} />)}
    </div>

    <div class="scroll-shadow-bottom"></div>
  </div>
</aside>

<button
  class="mobile-menu-button"
  type="button"
  data-sidebar-toggle
  aria-controls="docs-sidebar"
  aria-expanded="false"
  aria-label="Open documentation navigation"
>
  <AstroIcon name="hugeicons:menu-01" />
  <span class="mobile-menu-label">Menu</span>
</button>

<script>
  import { startSidebar } from "../scripts/sidebar";

  startSidebar();
</script>
