---
import PagesLayout from "../../layouts/PagesLayout.astro";
import { getDocEntries } from "../../lib/docs";

const overviewPages = (await getDocEntries()).filter((entry) => entry.label === "Overview" && entry.prettySegments.length === 1);
---

<PagesLayout
  title="Docs"
  description="Overview pages for the native initiative packages."
  breadcrumbs={[{ label: "Docs", href: "/docs/" }]}
>
  <h1>Documentation</h1>
  <p>Browse the package overviews, API guides, and supporting docs for the native initiative.</p>

  <section class="package-grid" aria-label="Documentation landing">
    {overviewPages.map((entry) => (
      <a class="package-card" href={entry.href}>
        <span class="package-label">{entry.prettySegments[0] === "native" ? "Framework" : "Package"}</span>
        <strong>{entry.prettySegments[0] === "native" ? "@okikio/native" : `@okikio/${entry.prettySegments[0]}`}</strong>
        <span>Open the overview and continue into the nested documentation tree.</span>
      </a>
    ))}
  </section>
</PagesLayout>
